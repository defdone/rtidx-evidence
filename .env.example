NODE_ENV=development
PORT=3000

# Optional. If unset, the app uses embedded local Postgres (PGlite under `.data/pglite/`) — no install, no `db/init.sql` step.
# Set this to use your own Postgres (Docker, cloud, or local server).
# DATABASE_URL=postgres://spin:spin@localhost:5432/spinbattles_assessment

# Hostname of the API machine for the background worker (localhost locally; service name in Docker).
WORKER_SOCKET_HOST=127.0.0.1

# Logging (pino): trace | debug | info | warn | error | fatal
LOG_LEVEL=info

# EVM JSON-RPC (optional; see TASK.md). If unset, worker uses mock verification.
RPC_URL=

# When true, worker skips live RPC and uses deterministic mock receipts (CI / offline).
# Default is true when DATABASE_URL is omitted (embedded mode); otherwise defaults to false unless set.
MOCK_CHAIN=true

# Live mode only: retries while waiting for getTransactionReceipt (pending).
RPC_RECEIPT_RETRIES=5
